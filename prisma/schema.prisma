generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & RBAC ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String
  phone         String?
  avatar        String?
  emailVerified DateTime?
  isActive      Boolean   @default(true)
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  districtId    String?
  district      District? @relation(fields: [districtId], references: [id])
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([roleId])
  @@index([districtId])
  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  slug        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  slug        String           @unique
  module      String
  action      String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Districts ─────────────────────────────────────────────────

model District {
  id               String              @id @default(cuid())
  name             String              @unique
  slug             String              @unique
  president        String?
  secretary        String?
  email            String?
  phone            String?
  address          String?
  isActive         Boolean             @default(true)
  users            User[]
  players          Player[]
  coaches          Coach[]
  clubMemberships  ClubMembership[]
  schoolMemberships SchoolMembership[]
  academyMemberships AcademyMembership[]
  tournaments      Tournament[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@map("districts")
}

// ─── Players ───────────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model Player {
  id           String            @id @default(cuid())
  playerId     String            @unique
  name         String
  dateOfBirth  DateTime
  gender       Gender
  email        String
  mobile       String
  photo        String?
  districtId   String
  district     District          @relation(fields: [districtId], references: [id])
  state        String            @default("Rajasthan")
  status       ApprovalStatus    @default(PENDING)
  approvedAt   DateTime?
  approvedBy   String?
  expiresAt    DateTime?
  certificates PlayerCertificate[]
  tournamentRegistrations TournamentRegistration[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([districtId])
  @@index([status])
  @@map("players")
}

model PlayerCertificate {
  id                String   @id @default(cuid())
  certificateNumber String   @unique
  playerId          String
  player            Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  qrCode            String   @unique
  issuedAt          DateTime @default(now())
  expiresAt         DateTime?
  pdfPath           String?
  isRevoked         Boolean  @default(false)
  revokedAt         DateTime?
  revokedReason     String?

  @@index([playerId])
  @@map("player_certificates")
}

// ─── Coaches ───────────────────────────────────────────────────

enum CertificationLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  INTERNATIONAL
}

model Coach {
  id              String            @id @default(cuid())
  coachId         String            @unique
  name            String
  email           String
  mobile          String
  photo           String?
  qualification   String
  certificationLevel CertificationLevel
  districtId      String
  district        District          @relation(fields: [districtId], references: [id])
  status          ApprovalStatus    @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?
  expiresAt       DateTime?
  certificates    CoachCertificate[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([districtId])
  @@index([status])
  @@map("coaches")
}

model CoachCertificate {
  id                String   @id @default(cuid())
  certificateNumber String   @unique
  coachId           String
  coach             Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  qrCode            String   @unique
  issuedAt          DateTime @default(now())
  expiresAt         DateTime?
  pdfPath           String?
  isRevoked         Boolean  @default(false)
  revokedAt         DateTime?
  revokedReason     String?

  @@index([coachId])
  @@map("coach_certificates")
}

// ─── Memberships ───────────────────────────────────────────────

enum MembershipType {
  CLUB
  SCHOOL
  ACADEMY
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  EXPIRED
  SUSPENDED
}

model ClubMembership {
  id              String           @id @default(cuid())
  membershipId    String           @unique
  clubName        String
  contactPerson   String
  email           String
  mobile          String
  address         String
  districtId      String
  district        District         @relation(fields: [districtId], references: [id])
  numberOfCourts  Int              @default(1)
  facilities      String?
  status          MembershipStatus @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?
  expiresAt       DateTime?
  certificatePath String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([districtId])
  @@index([status])
  @@map("club_memberships")
}

model SchoolMembership {
  id              String           @id @default(cuid())
  membershipId    String           @unique
  schoolName      String
  principalName   String
  email           String
  mobile          String
  address         String
  districtId      String
  district        District         @relation(fields: [districtId], references: [id])
  studentCount    Int?
  status          MembershipStatus @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?
  expiresAt       DateTime?
  certificatePath String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([districtId])
  @@index([status])
  @@map("school_memberships")
}

model AcademyMembership {
  id              String           @id @default(cuid())
  membershipId    String           @unique
  academyName     String
  directorName    String
  email           String
  mobile          String
  address         String
  districtId      String
  district        District         @relation(fields: [districtId], references: [id])
  coachCount      Int?
  status          MembershipStatus @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?
  expiresAt       DateTime?
  certificatePath String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([districtId])
  @@index([status])
  @@map("academy_memberships")
}

// ─── Tournaments ───────────────────────────────────────────────

enum TournamentCategory {
  JUNIOR
  SENIOR
  OPEN
  PROFESSIONAL
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Tournament {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  description     String?
  category        TournamentCategory
  status          TournamentStatus   @default(DRAFT)
  districtId      String?
  district        District?          @relation(fields: [districtId], references: [id])
  venue           String?
  startDate       DateTime
  endDate         DateTime
  registrationDeadline DateTime?
  maxParticipants Int?
  banner          String?
  registrations   TournamentRegistration[]
  fixtures        Fixture[]
  matches         Match[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([districtId])
  @@map("tournaments")
}

model TournamentRegistration {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerId     String
  player       Player     @relation(fields: [playerId], references: [id])
  seed         Int?
  status       ApprovalStatus @default(PENDING)
  registeredAt DateTime   @default(now())

  @@unique([tournamentId, playerId])
  @@map("tournament_registrations")
}

model Fixture {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        Int
  roundName    String
  matchNumber  Int
  player1Id    String?
  player2Id    String?
  winnerId     String?
  scheduledAt  DateTime?
  match        Match?

  @@index([tournamentId])
  @@map("fixtures")
}

model Match {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  fixtureId    String     @unique
  fixture      Fixture    @relation(fields: [fixtureId], references: [id])
  player1Score Int?
  player2Score Int?
  winnerId     String?
  status       String     @default("scheduled")
  playedAt     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tournamentId])
  @@map("matches")
}

// ─── Media CMS ─────────────────────────────────────────────────

model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  author      String?
  category    String?
  tags        String[]
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  metaTitle   String?
  metaDescription String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@map("news")
}

model Video {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  url         String
  thumbnail   String?
  category    String?
  tags        String[]
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@map("videos")
}

model Gallery {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String?
  category    String?
  isPublished Boolean       @default(false)
  publishedAt DateTime?
  images      GalleryImage[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([isPublished])
  @@map("galleries")
}

model GalleryImage {
  id        String  @id @default(cuid())
  galleryId String
  gallery   Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  alt       String?
  order     Int     @default(0)

  @@index([galleryId])
  @@map("gallery_images")
}

// ─── Donations ─────────────────────────────────────────────────

model Donation {
  id        String   @id @default(cuid())
  name      String
  email     String?
  mobile    String?
  amount    Float
  message   String?
  isAnonymous Boolean @default(false)
  createdAt DateTime @default(now())

  @@map("donations")
}

// ─── Contact ───────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model EquipmentOrder {
  id        String   @id @default(cuid())
  name      String
  mobile    String
  address   String
  district  String
  equipment String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("equipment_orders")
}

// ─── Website Content ───────────────────────────────────────────

model WebsiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String?
  content   String
  metadata  Json?
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("website_content")
}

model ExecutiveMember {
  id        String   @id @default(cuid())
  name      String
  designation String
  photo     String?
  bio       String?
  email     String?
  phone     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("executive_members")
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  website   String?
  type      String   @default("sponsor")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("partners")
}

// ─── Audit & Settings ──────────────────────────────────────────

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  DOWNLOAD
  APPROVE
  REJECT
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  module     String
  entityId   String?
  entityType String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  group     String   @default("general")
  updatedAt DateTime @updatedAt

  @@map("settings")
}
